// ══════════════════════════ STEP 6: VISUAL HULL ══════════════════════════
const hull = { az: 225, el: 22, zoom: 1, drag: null, grid: true };

function initVisualHull() {
  updateHullDims();
  const c = document.getElementById('hull-canvas');
  if (!c) return;
  c.onmousedown = (e) => { hull.drag = { x: e.clientX, az: hull.az }; c.style.cursor = 'grabbing'; };
  c.onmousemove = (e) => { if (!hull.drag) return; hull.az = hull.drag.az + (e.clientX - hull.drag.x) * 0.6; renderVisualHull(); };
  c.onmouseup = c.onmouseleave = () => { hull.drag = null; c.style.cursor = 'grab'; };
  c.onwheel = (e) => { e.preventDefault(); hull.zoom = Math.max(0.3, Math.min(4, hull.zoom * (e.deltaY < 0 ? 1.1 : 0.91))); renderVisualHull(); };
  renderVisualHull();
}

function updateHullDims() {
  ['W','H','D'].forEach(k => {
    const el = document.getElementById(`hull-dim-${k}`);
    if (el && S.dims) el.textContent = S.dims[k] !== '—' ? S.dims[k] : '—';
  });
}

function resetHullView() { hull.az = 225; hull.el = 22; hull.zoom = 1; renderVisualHull(); }

function toggleHullGrid() {
  hull.grid = !hull.grid;
  const btn = document.getElementById('hull-grid-btn');
  if (btn) {
    btn.style.background = hull.grid ? 'rgba(13,148,136,.15)' : 'var(--surface)';
    btn.style.color = hull.grid ? 'var(--teal-light)' : 'var(--subtle)';
    btn.style.borderColor = hull.grid ? 'var(--teal)' : 'var(--border)';
    btn.textContent = hull.grid ? 'רשת ✓' : 'רשת';
  }
  renderVisualHull();
}

function renderVisualHull() {
  const c = document.getElementById('hull-canvas');
  if (!c) return;
  const ctx = c.getContext('2d');
  const CW = c.parentElement.clientWidth - 2;
  const CH = Math.round(CW * 0.55);
  c.width = CW; c.height = CH;

  const dW = parseFloat(S.dims?.W) || 100;
  const dH = parseFloat(S.dims?.H) || 80;
  const dD = parseFloat(S.dims?.D) || 60;
  const maxDim = Math.max(dW, dH, dD, 1);
  const sc = Math.min(CW, CH) * 0.28 / maxDim * hull.zoom;

  const cx = CW / 2, cy = CH / 2 + dH * sc * 0.05;
  const azR = hull.az * Math.PI / 180;
  const elR = hull.el * Math.PI / 180;

  const proj = (x, y, z) => {
    const rx = x * Math.cos(azR) + z * Math.sin(azR);
    const rz = -x * Math.sin(azR) + z * Math.cos(azR);
    const ry = y * Math.cos(elR) - rz * Math.sin(elR);
    return { x: cx + rx * sc, y: cy - ry * sc };
  };

  ctx.fillStyle = '#F8FAFC';
  ctx.fillRect(0, 0, CW, CH);

  // Ground grid
  if (hull.grid) {
    const gs = maxDim * 1.3, step = maxDim / 4;
    ctx.strokeStyle = 'rgba(148,163,184,.22)'; ctx.lineWidth = 0.7;
    for (let i = -4; i <= 4; i++) {
      const g1 = proj(i*step, -dH/2, -gs/2), g2 = proj(i*step, -dH/2, gs/2);
      ctx.beginPath(); ctx.moveTo(g1.x,g1.y); ctx.lineTo(g2.x,g2.y); ctx.stroke();
      const g3 = proj(-gs/2, -dH/2, i*step), g4 = proj(gs/2, -dH/2, i*step);
      ctx.beginPath(); ctx.moveTo(g3.x,g3.y); ctx.lineTo(g4.x,g4.y); ctx.stroke();
    }
  }

  const hw = dW/2, hh = dH/2, hd = dD/2;
  const c3 = [
    [-hw,-hh,-hd],[hw,-hh,-hd],[hw,hh,-hd],[-hw,hh,-hd],
    [-hw,-hh, hd],[hw,-hh, hd],[hw,hh, hd],[-hw,hh, hd]
  ];
  const p2 = c3.map(([x,y,z]) => proj(x,y,z));

  const viewDir = [
    Math.cos(azR)*Math.cos(elR),
    Math.sin(elR),
    Math.sin(azR)*Math.cos(elR)
  ];
  const dot3 = (n) => n[0]*viewDir[0]+n[1]*viewDir[1]+n[2]*viewDir[2];

  const faces = [
    { idx:[3,2,1,0], norm:[0,0,-1], poly:'front', color:'rgba(13,148,136,.14)' },
    { idx:[4,5,6,7], norm:[0,0,1],  poly:null,    color:'rgba(13,148,136,.05)' },
    { idx:[7,6,2,3], norm:[0,1,0],  poly:'top',   color:'rgba(99,102,241,.14)' },
    { idx:[0,1,5,4], norm:[0,-1,0], poly:null,    color:'rgba(100,116,139,.06)' },
    { idx:[1,2,6,5], norm:[1,0,0],  poly:'side',  color:'rgba(249,115,22,.14)' },
    { idx:[4,7,3,0], norm:[-1,0,0], poly:null,    color:'rgba(249,115,22,.05)' },
  ].map(f => {
    const cDepth = f.idx.reduce((s,i) => s + c3[i][0]*Math.sin(azR) - c3[i][2]*Math.cos(azR), 0)/4;
    return { ...f, dot: dot3(f.norm), cDepth };
  }).sort((a,b) => a.cDepth - b.cDepth);

  // Draw faces + silhouettes
  faces.forEach(f => {
    const fp = f.idx.map(i => p2[i]);
    ctx.beginPath(); ctx.moveTo(fp[0].x,fp[0].y); fp.slice(1).forEach(p=>ctx.lineTo(p.x,p.y)); ctx.closePath();
    ctx.fillStyle = f.dot > 0 ? f.color : 'rgba(15,23,42,.04)'; ctx.fill();
    ctx.strokeStyle = '#CBD5E1'; ctx.lineWidth = 0.8; ctx.stroke();

    // Silhouette projection on visible faces
    if (f.dot > 0.05 && f.poly) {
      const poly = S.polys[f.poly];
      if (!poly || poly.pts.length < 3) return;
      const srcW = S.polyCanvasSize?.[f.poly]?.w ?? 1;
      const srcH = S.polyCanvasSize?.[f.poly]?.h ?? 1;
      // Face axes in 3D (u = right along face, v = down along face)
      const [fc0,fc1,,fc3] = f.idx.map(i => c3[i]);
      const fu = [fc1[0]-fc0[0], fc1[1]-fc0[1], fc1[2]-fc0[2]];
      const fv = [fc3[0]-fc0[0], fc3[1]-fc0[1], fc3[2]-fc0[2]];
      const mapFace = (u,v) => proj(fc0[0]+fu[0]*u+fv[0]*v, fc0[1]+fu[1]*u+fv[1]*v, fc0[2]+fu[2]*u+fv[2]*v);
      ctx.save();
      ctx.beginPath(); ctx.moveTo(fp[0].x,fp[0].y); fp.slice(1).forEach(p=>ctx.lineTo(p.x,p.y)); ctx.closePath(); ctx.clip();
      ctx.beginPath();
      const p0 = mapFace(poly.pts[0].x/srcW, poly.pts[0].y/srcH);
      ctx.moveTo(p0.x, p0.y);
      poly.pts.slice(1).forEach(pt => { const p = mapFace(pt.x/srcW, pt.y/srcH); ctx.lineTo(p.x,p.y); });
      if (poly.closed) ctx.closePath();
      ctx.strokeStyle = '#0D9488'; ctx.lineWidth = 1.5; ctx.stroke();
      if (poly.closed) { ctx.fillStyle = 'rgba(13,148,136,.12)'; ctx.fill(); }
      ctx.restore();
    }
  });

  // Edges
  [[0,1],[1,2],[2,3],[3,0],[4,5],[5,6],[6,7],[7,4],[0,4],[1,5],[2,6],[3,7]].forEach(([a,b]) => {
    ctx.beginPath(); ctx.moveTo(p2[a].x,p2[a].y); ctx.lineTo(p2[b].x,p2[b].y);
    ctx.strokeStyle = '#475569'; ctx.lineWidth = 1.2; ctx.stroke();
  });

  // Dim labels
  ctx.font = 'bold 11px Fira Code, monospace'; ctx.fillStyle = '#64748B';
  const wM = { x:(p2[0].x+p2[1].x)/2, y:(p2[0].y+p2[1].y)/2+14 };
  ctx.textAlign='center'; ctx.fillText(`W=${dW}mm`, wM.x, wM.y);
  const hM = { x:(p2[1].x+p2[2].x)/2+14, y:(p2[1].y+p2[2].y)/2 };
  ctx.textAlign='left'; ctx.fillText(`H=${dH}mm`, hM.x, hM.y);
  const dM = { x:(p2[1].x+p2[5].x)/2+10, y:(p2[1].y+p2[5].y)/2+10 };
  ctx.textAlign='left'; ctx.fillText(`D=${dD}mm`, dM.x, dM.y);

  // Axes indicator (bottom-left)
  const ax = 48, ay = CH - 38, axLen = 22;
  [[[1,0,0],'#EF4444','X'],[[0,1,0],'#22C55E','Y'],[[0,0,1],'#3B82F6','Z']].forEach(([dir,color,lbl]) => {
    const tip = proj(dir[0]*axLen/sc, dir[1]*axLen/sc, dir[2]*axLen/sc);
    ctx.beginPath(); ctx.moveTo(ax,ay); ctx.lineTo(ax+(tip.x-cx), ay+(tip.y-cy));
    ctx.strokeStyle=color; ctx.lineWidth=2; ctx.stroke();
    ctx.fillStyle=color; ctx.font='bold 9px sans-serif'; ctx.textAlign='center';
    ctx.fillText(lbl, ax+(tip.x-cx)*1.35, ay+(tip.y-cy)*1.35+3);
  });
}

// ══════════════════════════ STEP 7: VECTORIZATION ══════════════════════════
let vecView = 'front';

function initVectorize() { setVecView('front'); }

function setVecView(v) {
  vecView = v;
  document.querySelectorAll('.vec-tab').forEach(t => {
    const a = t.dataset.v === v;
    t.style.background = a ? 'var(--teal)' : 'var(--surface)';
    t.style.color = a ? 'white' : 'var(--subtle)';
    t.style.borderColor = a ? 'var(--teal)' : 'var(--border)';
  });
  renderVectorize();
}

function renderVectorize() {
  const c = document.getElementById('vec-canvas');
  if (!c) return;
  const ctx = c.getContext('2d');
  const eps = parseInt(document.getElementById('vec-eps')?.value ?? 5);
  const epsEl = document.getElementById('vec-eps-val');
  if (epsEl) epsEl.textContent = `${eps} px`;

  const url = S.imgs[vecView];
  if (!url) {
    c.width = 400; c.height = 280; ctx.fillStyle = '#1E293B'; ctx.fillRect(0,0,400,280);
    ctx.fillStyle='#475569'; ctx.font='14px sans-serif'; ctx.textAlign='center';
    ctx.fillText('אין תמונה', 200, 140); updateVecStats([],[]); return;
  }

  const img = new Image();
  img.onload = () => {
    const maxW = c.parentElement.offsetWidth - 2;
    const r = Math.min(maxW/img.width, 420/img.height, 1);
    c.width = Math.round(img.width*r); c.height = Math.round(img.height*r);
    ctx.drawImage(img, 0, 0, c.width, c.height);
    ctx.fillStyle='rgba(15,23,42,.45)'; ctx.fillRect(0,0,c.width,c.height);

    const poly = S.polys[vecView];
    if (!poly || poly.pts.length < 3) { updateVecStats([],[]); return; }

    const srcW = S.polyCanvasSize?.[vecView]?.w ?? c.width;
    const srcH = S.polyCanvasSize?.[vecView]?.h ?? c.height;
    const sx = c.width/srcW, sy = c.height/srcH;
    const pts = poly.pts.map(p => ({ x:p.x*sx, y:p.y*sy }));

    const simplified = douglasPeucker(pts, eps);
    const segs = classifyVecSegments(pts, simplified, poly.closed);

    const lines = segs.filter(s=>s.type==='line');
    const arcs  = segs.filter(s=>s.type==='arc');
    const curves = segs.filter(s=>s.type==='curve');

    // Draw free curves (orange dashes)
    curves.forEach(s => {
      ctx.beginPath(); ctx.moveTo(s.pts[0].x,s.pts[0].y);
      s.pts.forEach(p=>ctx.lineTo(p.x,p.y));
      ctx.strokeStyle='#F97316'; ctx.lineWidth=2;
      ctx.setLineDash([5,3]); ctx.stroke(); ctx.setLineDash([]);
    });

    // Draw RANSAC arcs (purple) — show fitted circle center + radius
    arcs.forEach(s => {
      ctx.beginPath(); ctx.moveTo(s.pts[0].x,s.pts[0].y);
      s.pts.forEach(p=>ctx.lineTo(p.x,p.y));
      ctx.strokeStyle='#A78BFA'; ctx.lineWidth=2.5; ctx.stroke();
      if (s.arc) {
        // Draw circle center cross
        const {cx,cy,r}=s.arc;
        ctx.strokeStyle='rgba(167,139,250,.4)'; ctx.lineWidth=1; ctx.setLineDash([3,3]);
        ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2); ctx.stroke();
        ctx.setLineDash([]);
        ctx.beginPath(); ctx.moveTo(cx-6,cy); ctx.lineTo(cx+6,cy);
        ctx.moveTo(cx,cy-6); ctx.lineTo(cx,cy+6);
        ctx.strokeStyle='#A78BFA'; ctx.lineWidth=1.2; ctx.stroke();
      }
    });

    // Draw RANSAC straight lines (teal solid)
    lines.forEach(s => {
      const a=s.pts[0], b=s.pts[s.pts.length-1];
      ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);
      ctx.strokeStyle='#0D9488'; ctx.lineWidth=2.2; ctx.stroke();
      [a,b].forEach(p => {
        ctx.beginPath(); ctx.arc(p.x,p.y,4,0,Math.PI*2);
        ctx.fillStyle='#14B8A6'; ctx.fill();
        ctx.strokeStyle='#0F172A'; ctx.lineWidth=1; ctx.stroke();
      });
    });

    updateVecStats(lines, arcs, curves);
  };
  img.src = url;
}

// RANSAC-enhanced segment classification (Fischler & Bolles 1981 — Szeliski Ch.6)
// Tries to fit a line and a circle to each segment's points
// Returns type='line', 'arc', or 'curve' with optional circle metadata
function classifyVecSegments(allPts, simplified, closed) {
  if (simplified.length < 2) return [];
  const findIdx = (pt) => allPts.reduce((b,p,i) => {
    const d=(p.x-pt.x)**2+(p.y-pt.y)**2; return d<b.d?{i,d}:b;
  }, {i:0,d:Infinity}).i;

  const nodes = simplified.map(findIdx);
  const n = nodes.length;
  const segs = [];

  for (let i = 0; i < (closed ? n : n-1); i++) {
    const from = nodes[i], to = nodes[(i+1)%n];
    let segPts;
    if (to > from) { segPts = allPts.slice(from, to+1); }
    else if (closed) { segPts = [...allPts.slice(from), ...allPts.slice(0, to+1)]; }
    else { continue; }
    if (segPts.length < 2) continue;

    const a=segPts[0], b=segPts[segPts.length-1];

    // Sample up to 40 evenly-spaced points for RANSAC (performance)
    const step = Math.max(1, Math.floor(segPts.length/40));
    const sample = segPts.filter((_,ii)=>ii%step===0);

    // Try RANSAC line fit
    const lineFit = ransacFitLine(sample, 3, 60);
    if (lineFit) {
      segs.push({ type:'line', pts:segPts, from:a, to:b });
      continue;
    }

    // Try RANSAC circle fit (arc)
    const cirFit = sample.length >= 5 ? ransacFitCircle(sample, 4, 120) : null;
    if (cirFit) {
      segs.push({ type:'arc', pts:segPts, from:a, to:b,
        arc:{ cx:cirFit.cx, cy:cirFit.cy, r:cirFit.r, inliers:cirFit.n } });
      continue;
    }

    // Fallback: classify by max deviation from chord
    const dx=b.x-a.x, dy=b.y-a.y, len=Math.sqrt(dx*dx+dy*dy)||1;
    const maxDev = segPts.reduce((m,p) => Math.max(m, Math.abs(dy*p.x-dx*p.y+b.x*a.y-b.y*a.x)/len), 0);
    segs.push({ type: maxDev<5?'line':'curve', pts:segPts, from:a, to:b });
  }
  return segs;
}

function updateVecStats(lines, arcs=[], curves=[]) {
  const el = document.getElementById('vec-stats');
  if (!el) return;
  const ppm = S.scale[vecView];
  const srcW = S.polyCanvasSize?.[vecView]?.w ?? 1;
  const c = document.getElementById('vec-canvas');
  const dispScale = c ? c.width / srcW : 1;

  const pxToMm = (px) => ppm ? (px/dispScale/ppm) : null;
  const fmtLen = (a,b) => {
    const mm = pxToMm(Math.sqrt((b.x-a.x)**2+(b.y-a.y)**2));
    return mm!=null ? `<b>${mm.toFixed(1)}</b> מ"מ` : `${Math.round(Math.sqrt((b.x-a.x)**2+(b.y-a.y)**2)/dispScale)} px`;
  };
  const fmtAngle = (a,b) => {
    const deg = Math.atan2(b.y-a.y, b.x-a.x) * 180/Math.PI;
    return `${((deg+360)%180).toFixed(1)}°`;
  };

  // Total perimeter
  let perimPx = 0;
  [...lines,...arcs,...curves].forEach(s => {
    for (let i=0;i<s.pts.length-1;i++) {
      const dx=s.pts[i+1].x-s.pts[i].x, dy=s.pts[i+1].y-s.pts[i].y;
      perimPx+=Math.sqrt(dx*dx+dy*dy);
    }
  });
  const perimMm = pxToMm(perimPx);
  const perimStr = perimMm!=null ? `${perimMm.toFixed(1)} מ"מ` : `${Math.round(perimPx/dispScale)} px`;

  const linesHTML = lines.map((s,i) => {
    const a=s.pts[0], b=s.pts[s.pts.length-1];
    return `<div style="padding:4px 6px;margin-bottom:3px;background:rgba(20,184,166,.07);border-radius:6px;font-family:'Fira Code',monospace;font-size:11px;display:flex;gap:8px;align-items:center;">
      <span style="color:#14B8A6;font-size:13px;">━</span>
      <span style="color:var(--subtle);">קו ${i+1}</span>
      <span style="color:var(--text);">${fmtLen(a,b)}</span>
      <span style="color:var(--muted);margin-right:auto;">${fmtAngle(a,b)}</span>
    </div>`;
  }).join('');

  // RANSAC arcs with circle radius
  const arcsHTML = arcs.map((s,i) => {
    const rMm = s.arc ? pxToMm(s.arc.r) : null;
    const rStr = rMm!=null ? `R=${rMm.toFixed(1)} מ"מ` : s.arc ? `R=${Math.round(s.arc.r/dispScale)} px` : '';
    return `<div style="padding:4px 6px;margin-bottom:3px;background:rgba(167,139,250,.07);border-radius:6px;font-family:'Fira Code',monospace;font-size:11px;display:flex;gap:8px;align-items:center;">
      <span style="color:#A78BFA;font-size:13px;">⌒</span>
      <span style="color:var(--subtle);">קשת ${i+1}</span>
      <span style="color:#C4B5FD;font-weight:600;">${rStr}</span>
    </div>`;
  }).join('');

  const curvesHTML = curves.map((_,i) =>
    `<div style="padding:4px 6px;margin-bottom:3px;background:rgba(249,115,22,.07);border-radius:6px;font-size:11px;color:var(--muted);">
      <span style="color:#F97316;">~</span> עקום חופשי ${i+1}
    </div>`
  ).join('');

  const totalSegs = lines.length+arcs.length+curves.length;
  el.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:4px;margin-bottom:10px;">
      <div style="background:var(--bg);border-radius:8px;padding:6px;text-align:center;">
        <div style="font-size:16px;font-weight:700;color:#14B8A6;font-family:'Fira Code',monospace;">${lines.length}</div>
        <div style="font-size:9px;color:var(--muted);">קווים</div>
      </div>
      <div style="background:var(--bg);border-radius:8px;padding:6px;text-align:center;">
        <div style="font-size:16px;font-weight:700;color:#A78BFA;font-family:'Fira Code',monospace;">${arcs.length}</div>
        <div style="font-size:9px;color:var(--muted);">קשתות RANSAC</div>
      </div>
      <div style="background:var(--bg);border-radius:8px;padding:6px;text-align:center;">
        <div style="font-size:16px;font-weight:700;color:#F97316;font-family:'Fira Code',monospace;">${curves.length}</div>
        <div style="font-size:9px;color:var(--muted);">עקומות</div>
      </div>
      <div style="background:var(--bg);border-radius:8px;padding:6px;text-align:center;">
        <div style="font-size:12px;font-weight:700;color:var(--teal-light);font-family:'Fira Code',monospace;">${perimStr}</div>
        <div style="font-size:9px;color:var(--muted);">היקף</div>
      </div>
    </div>
    <div style="max-height:220px;overflow-y:auto;">
      ${linesHTML}${arcsHTML}${curvesHTML}
      ${!totalSegs ? '<div style="font-size:11px;color:var(--border);padding:8px 0;text-align:center;">אין נתוני מתאר</div>' : ''}
    </div>`;
}

// ══════════════════════════ SAVE / NEW ══════════════════════════
async function newProject() {
  if (!confirm('למחוק את הפרויקט הנוכחי ולהתחיל מחדש?')) return;
  for (const v of ['front','side','top','iso']) await IDB.del(`img-${v}`);
  await IDB.del('state');
  await IDB.del('measurements');
  location.reload();
}

function saveProject() {
  const blob = new Blob([JSON.stringify({ scale: S.scale, polys: S.polys, step: S.step }, null, 2)], { type: 'application/json' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'td-project.json'; a.click();
}
</script>

