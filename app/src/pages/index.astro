---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="TD Maker">
<div id="app" style="height:100vh;display:flex;flex-direction:column;overflow:hidden;">

  <!-- ══════════════ HEADER ══════════════ -->
  <header style="height:56px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;gap:16px;flex-shrink:0;">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2.5">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <line x1="3" y1="9" x2="21" y2="9"/>
      <line x1="9" y1="3" x2="9" y2="21"/>
    </svg>
    <span style="font-family:'Fira Code',monospace;font-weight:700;font-size:18px;color:var(--teal-light);">TD Maker</span>
    <div style="flex:1;"></div>
    <span id="step-label" style="font-size:13px;color:var(--muted);">שלב 1 מתוך 10</span>
    <div style="width:120px;height:5px;background:var(--border);border-radius:999px;overflow:hidden;">
      <div id="progress-bar" style="height:100%;width:10%;background:var(--teal);border-radius:999px;transition:width 0.35s;"></div>
    </div>
    <button onclick="printCalibration()" title="הדפס דף כיול" style="font-size:13px;padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;display:flex;align-items:center;gap:6px;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      כיול
    </button>
    <button onclick="newProject()" style="font-size:13px;padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;">+ חדש</button>
    <button onclick="saveProject()" style="font-size:13px;padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;">שמור</button>
  </header>

  <!-- ══════════════ CAMERA MODAL ══════════════ -->
  <div id="camera-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:100;flex-direction:column;align-items:center;justify-content:center;gap:16px;">
    <video id="camera-video" autoplay playsinline style="display:none;"></video>
    <canvas id="camera-canvas" style="border-radius:12px;background:#000;max-width:90vw;max-height:65vh;"></canvas>
    <div style="display:flex;gap:12px;align-items:center;">
      <button onclick="rotateCamera()" title="סובב 90°" style="padding:10px 18px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:22px;border:1px solid var(--border);cursor:pointer;line-height:1;">↻</button>
      <button onclick="capturePhoto()" style="padding:12px 32px;border-radius:10px;background:var(--teal);color:white;font-size:15px;font-weight:700;border:none;cursor:pointer;">צלם</button>
      <button onclick="closeCamera()" style="padding:12px 24px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:14px;border:1px solid var(--border);cursor:pointer;">ביטול</button>
    </div>
  </div>

  <!-- ══════════════ CROP MODAL ══════════════ -->
  <div id="crop-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:100;flex-direction:column;align-items:center;justify-content:center;gap:14px;">
    <div style="font-size:12px;color:var(--muted);">גרור להזזה • פינות לשינוי גודל • לחץ מחוץ לאזור לחיתוך חדש</div>
    <canvas id="crop-canvas" style="border-radius:8px;cursor:crosshair;max-width:92vw;max-height:72vh;display:block;"></canvas>
    <div style="display:flex;gap:10px;align-items:center;">
      <button onclick="applyCrop()" style="padding:10px 28px;border-radius:10px;background:var(--teal);color:white;font-size:14px;font-weight:700;border:none;cursor:pointer;">חתוך ✓</button>
      <button onclick="resetCropRect()" style="padding:10px 18px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:13px;border:1px solid var(--border);cursor:pointer;">איפוס</button>
      <button onclick="closeCrop()" style="padding:10px 18px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:13px;border:1px solid var(--border);cursor:pointer;">ביטול</button>
    </div>
  </div>

  <!-- ══════════════ BODY ══════════════ -->
  <div style="display:flex;flex:1;overflow:hidden;">

    <!-- ── SIDEBAR ── -->
    <aside id="sidebar" style="width:228px;flex-shrink:0;background:var(--surface);border-left:1px solid var(--border);overflow-y:auto;padding:10px;"></aside>

    <!-- ── MAIN ── -->
    <main id="main" style="flex:1;overflow-y:auto;">

      <!-- ─── STEP 1: Upload ─── -->
      <section class="panel" data-panel="1" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">העלאת תמונות</h2>
        <p style="color:var(--muted);margin:0 0 28px;font-size:14px;">העלה 3 צילומים — פנים, צד, על. הנח סרגל בכל תמונה.</p>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:24px;">
          {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
            <div>
              <div style="font-size:11px;font-weight:700;letter-spacing:.07em;color:var(--subtle);margin-bottom:8px;text-transform:uppercase;">{label}</div>
              <div class="upload-zone" data-view={v} onclick={`triggerUpload('${v}')`}
                style="height:200px;border:2px dashed var(--border);border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;background:var(--bg);transition:border-color .2s;">
                <img id={`preview-${v}`} style="display:none;width:100%;height:100%;object-fit:contain;position:absolute;inset:0;" />
                <button id={`delete-${v}`} onclick={`event.stopPropagation();deleteImg('${v}')`}
                  style="display:none;position:absolute;top:6px;right:6px;z-index:10;width:26px;height:26px;border-radius:50%;border:none;background:rgba(239,68,68,.85);color:white;font-size:15px;line-height:1;cursor:pointer;align-items:center;justify-content:center;">✕</button>
                <button id={`crop-${v}`} onclick={`event.stopPropagation();openCrop('${v}')`}
                  style="display:none;position:absolute;top:6px;left:6px;z-index:10;padding:3px 9px;border-radius:6px;border:none;background:rgba(13,148,136,.88);color:white;font-size:11px;font-weight:700;cursor:pointer;">חתוך</button>
                <div id={`placeholder-${v}`} style="display:flex;flex-direction:column;align-items:center;gap:10px;color:var(--border);pointer-events:none;">
                  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                    <circle cx="12" cy="13" r="4"/>
                  </svg>
                  <span style="font-size:13px;">לחץ להעלאה</span>
                </div>
              </div>
              <div style="display:flex;gap:6px;margin-top:7px;">
                <input type="file" id={`input-${v}`} accept="image/*" style="display:none" onchange={`handleUpload(event,'${v}')`} />
                <button onclick={`triggerUpload('${v}')`} style="flex:1;padding:5px 0;border-radius:7px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">קובץ</button>
                <button onclick={`openCamera('${v}')`} style="flex:1;padding:5px 0;border-radius:7px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:4px;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                  מצלמה
                </button>
              </div>
            </div>
          ))}
        </div>

        <!-- תמונה איזומטרית — אופציונלי -->
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;gap:16px;">
          <div class="upload-zone" data-view="iso" onclick="triggerUpload('iso')"
            style="width:130px;height:90px;border:2px dashed var(--border);border-radius:10px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;background:var(--bg);">
            <img id="preview-iso" style="display:none;width:100%;height:100%;object-fit:contain;position:absolute;inset:0;" />
            <button id="crop-iso" onclick="event.stopPropagation();openCrop('iso')"
              style="display:none;position:absolute;top:4px;left:4px;z-index:10;padding:2px 7px;border-radius:5px;border:none;background:rgba(13,148,136,.88);color:white;font-size:10px;font-weight:700;cursor:pointer;">חתוך</button>
            <div id="placeholder-iso" style="display:flex;flex-direction:column;align-items:center;gap:5px;color:var(--border);pointer-events:none;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
              <span style="font-size:11px;">העלה</span>
            </div>
          </div>
          <input type="file" id="input-iso" accept="image/*" style="display:none" onchange="handleUpload(event,'iso')" />
          <div>
            <div style="font-size:12px;font-weight:700;color:var(--teal-light);margin-bottom:4px;">תמונה איזומטרית <span style="font-weight:400;color:var(--muted);font-size:11px;">(אופציונלי)</span></div>
            <div style="font-size:12px;color:var(--muted);line-height:1.6;">תמונה שמראה כמה מבטים — פנים + צד + על בבת אחת.<br/>מגדילה את דיוק השחזור התלת-מימדי.</div>
            <div style="display:flex;gap:6px;margin-top:8px;">
              <button onclick="triggerUpload('iso')" style="padding:4px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:11px;cursor:pointer;">קובץ</button>
              <button onclick="openCamera('iso')" style="padding:4px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:4px;">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                מצלמה
              </button>
            </div>
          </div>
        </div>

        <div id="upload-status" style="font-size:13px;color:var(--muted);min-height:20px;margin-bottom:16px;"></div>
        <div style="display:flex;justify-content:flex-end;">
          <button id="step1-next" onclick="nextStep()" disabled
            style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--border);color:var(--muted);cursor:not-allowed;transition:all .2s;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 4: Scale ─── -->
      <section class="panel" data-panel="4" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">קנה מידה</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">לחץ על שתי נקודות, הכנס מרחק ב-מ"מ ולחץ <strong style="color:var(--text);">הוסף מדידה</strong>. הוסף כמה מדידות שתרצה לדיוק מרבי.</p>

        <div style="display:flex;gap:8px;margin-bottom:14px;">
          {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
            <button class="scale-tab" data-v={v} onclick={`setScaleView('${v}')`}
              style="padding:6px 18px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:13px;cursor:pointer;">{label}</button>
          ))}
        </div>

        <!-- Auto ruler detect bar -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;background:rgba(13,148,136,.06);border:1px solid rgba(13,148,136,.22);border-radius:10px;padding:9px 14px;">
          <button onclick="autoDetectScale()" style="padding:6px 16px;border-radius:8px;background:rgba(13,148,136,.15);border:1px solid var(--teal);color:var(--teal-light);font-size:13px;font-weight:600;cursor:pointer;">🔍 זיהוי סרגל אוטומטי</button>
          <span id="ruler-detect-info" style="font-size:12px;color:var(--muted);">מזהה סרגל בתמונה — ללא לחיצות</span>
        </div>

        <div style="display:grid;grid-template-columns:1fr 320px;gap:16px;align-items:start;">

          <!-- Left: canvas + controls -->
          <div>
            <div style="background:var(--bg);border-radius:12px;overflow:hidden;margin-bottom:12px;display:flex;justify-content:center;align-items:center;min-height:180px;">
              <canvas id="scale-canvas" style="max-width:100%;cursor:crosshair;"></canvas>
            </div>

            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
              <span id="scale-pts-info" style="font-size:12px;color:var(--muted);font-family:'Fira Code',monospace;flex:1;">לחץ על נקודה 1 על הסרגל</span>
              <input id="mm-input" type="number" min="0.1" step="0.1" placeholder="מ״מ"
                style="width:76px;padding:7px 10px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:14px;font-family:'Fira Code',monospace;text-align:center;" />
              <span style="font-size:12px;color:var(--muted);">מ"מ</span>
              <button onclick="addMeasurement()" style="padding:7px 16px;border-radius:8px;background:var(--teal);color:white;border:none;font-size:13px;font-weight:600;cursor:pointer;">+ הוסף מדידה</button>
            </div>
          </div>

          <!-- Right: measurements list per view -->
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
              <span style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;">מדידות</span>
              <span id="meas-view-label" style="font-size:12px;color:var(--teal-light);font-weight:600;"></span>
            </div>

            <div id="meas-list" style="min-height:80px;margin-bottom:12px;">
              <div style="font-size:12px;color:var(--border);text-align:center;padding:20px 0;">אין מדידות עדיין</div>
            </div>

            <div style="border-top:1px solid var(--border);padding-top:10px;">
              <div style="display:flex;justify-content:space-between;align-items:center;">
                <span style="font-size:12px;color:var(--muted);">ממוצע:</span>
                <div style="text-align:left;">
                  <span id="scale-avg" style="font-size:20px;font-weight:700;font-family:'Fira Code',monospace;color:var(--subtle);">—</span>
                  <span style="font-size:11px;color:var(--muted);margin-right:4px;"> px/mm</span>
                </div>
              </div>
            </div>

            <!-- Summary: all 3 views -->
            <div style="border-top:1px solid var(--border);margin-top:10px;padding-top:10px;display:grid;grid-template-columns:repeat(3,1fr);gap:6px;">
              {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
                <div style="text-align:center;">
                  <div style="font-size:10px;color:var(--muted);margin-bottom:2px;">{label}</div>
                  <div id={`scale-${v}`} style="font-size:13px;font-weight:700;font-family:'Fira Code',monospace;color:var(--subtle);">—</div>
                </div>
              ))}
            </div>
          </div>

        </div>

        <div style="display:flex;justify-content:space-between;margin-top:24px;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button id="step4-next" onclick="nextStep()" disabled
            style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--border);color:var(--muted);cursor:not-allowed;transition:all .2s;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 3: Contour (was 4) moved before scale ─── -->
      <!-- ─── STEP 2: Segmentation ─── -->
      <section class="panel" data-panel="2" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">הפרדת רקע</h2>
        <p style="color:var(--muted);margin:0 0 20px;font-size:14px;">כוון את הסף כדי לקבל מסכת סילואט נקייה של האובייקט.</p>

        <div style="display:flex;gap:8px;margin-bottom:16px;">
          {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
            <button class="seg-tab" data-v={v} onclick={`setSegView('${v}')`}
              style="padding:6px 18px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:13px;cursor:pointer;">{label}</button>
          ))}
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px;">
          <div style="position:relative;">
            <div style="font-size:12px;color:var(--muted);margin-bottom:6px;">מקור</div>
            <canvas id="seg-src" style="width:100%;border-radius:8px;cursor:crosshair;"></canvas>
            <!-- calibration corner overlay -->
            <canvas id="seg-cal-overlay" style="position:absolute;top:22px;left:0;width:100%;height:calc(100% - 22px);border-radius:8px;pointer-events:none;"></canvas>
          </div>
          <div>
            <div style="font-size:12px;color:var(--muted);margin-bottom:6px;">סילואט</div>
            <canvas id="seg-out" style="width:100%;border-radius:8px;"></canvas>
          </div>
        </div>
        <!-- calibration background status bar -->
        <div id="cal-bg-bar" style="display:none;background:rgba(124,58,237,.12);border:1px solid #7C3AED;border-radius:8px;padding:7px 12px;margin-bottom:8px;font-size:12px;color:#A78BFA;display:flex;align-items:center;gap:8px;">
          <span>📐</span>
          <span id="cal-bg-msg">לחץ על 4 פינות הרשת בתמונה (UL → UR → DR → DL)</span>
          <button onclick="calBgCancel()" style="margin-right:auto;padding:2px 8px;border-radius:5px;border:1px solid #7C3AED;background:transparent;color:#A78BFA;font-size:11px;cursor:pointer;">ביטול</button>
        </div>

        <div style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;">
          <button onclick="segAutoOtsu()" style="padding:5px 12px;border-radius:8px;border:1px solid var(--teal);background:rgba(13,148,136,.1);color:var(--teal-light);font-size:12px;cursor:pointer;font-weight:600;">✦ Otsu אוטו</button>
          <button onclick="setSegMode('dark')" id="seg-mode-dark" style="padding:5px 12px;border-radius:8px;border:1px solid var(--teal);background:rgba(13,148,136,.15);color:var(--teal-light);font-size:12px;cursor:pointer;">● אובייקט כהה</button>
          <button onclick="setSegMode('light')" id="seg-mode-light" style="padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">○ אובייקט בהיר</button>
          <button onclick="segMorphClean()" style="padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">⬜ נקה רעש</button>
          <button onclick="gmmSegment()" title="GMM Color Segmentation — GrabCut simplified (Rother 2004)" style="padding:5px 12px;border-radius:8px;border:1px solid #7C3AED;background:rgba(124,58,237,.1);color:#A78BFA;font-size:12px;cursor:pointer;font-weight:600;">🧩 GMM</button>
          <button onclick="startCalBgMode()" title="חיסור רקע דף כיול — לחץ 4 פינות הרשת" style="padding:5px 12px;border-radius:8px;border:1px solid #F59E0B;background:rgba(245,158,11,.1);color:#FCD34D;font-size:12px;cursor:pointer;font-weight:600;">📐 כיול רקע</button>
          <button id="seg-save-btn" onclick="saveSegSettings()" title="שמור הגדרות סף + מצב לכל המבטים" style="padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">💾 שמור הגדרות</button>
        </div>
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:28px;">
          <label style="font-size:13px;color:var(--subtle);width:60px;">סף:</label>
          <input id="seg-slider" type="range" min="30" max="240" value="120" oninput="applyThreshold()"
            style="flex:1;" />
          <span id="seg-val" style="font-family:'Fira Code',monospace;font-size:13px;color:var(--teal-light);width:36px;">120</span>
        </div>

        <div style="display:flex;justify-content:space-between;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 3: Contour ─── -->
      <section class="panel" data-panel="3" style="padding:16px 24px;display:none;">
        <h2 style="font-size:20px;font-weight:700;margin:0 0 4px;">ציור מתאר</h2>
        <p style="color:var(--muted);margin:0 0 10px;font-size:13px;">לחץ על גבולות האובייקט, או השתמש בזיהוי אוטומטי. גלגל עכבר להגדלה, גרירה להזזה.</p>

        <!-- Row 1: view tabs + auto button -->
        <div style="display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap;">
          {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
            <button class="contour-tab" data-v={v} onclick={`setContourView('${v}')`}
              style="padding:6px 18px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:13px;cursor:pointer;">
              {label}<span id={`ctab-seg-${v}`} style="color:transparent;font-size:11px;"> ✓</span>
            </button>
          ))}
          <div style="flex:1;"></div>
          <div style="display:flex;align-items:center;gap:6px;background:rgba(13,148,136,.08);border:1px solid var(--teal);border-radius:8px;padding:4px 10px;">
            <button onclick="autoDetectContour()" style="background:none;border:none;color:var(--teal-light);font-size:13px;font-weight:600;cursor:pointer;">✦ זיהוי אוטומטי</button>
            <span style="font-size:11px;color:var(--muted);">רגישות:</span>
            <input id="canny-sens" type="range" min="1" max="10" value="5" style="width:65px;accent-color:#0D9488;" oninput="document.getElementById('canny-sens-val').textContent=this.value" />
            <span id="canny-sens-val" style="font-size:11px;font-family:'Fira Code',monospace;color:var(--teal-light);width:14px;">5</span>
            <span style="width:1px;height:16px;background:var(--border);margin:0 2px;"></span>
            <label style="font-size:11px;color:var(--muted);">שיפור:</label>
            <select id="enhance-mode" onchange="autoDetectContour()" style="padding:2px 6px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--teal-light);font-size:11px;font-weight:600;cursor:pointer;">
              <option value="clahe" selected>CLAHE ✓</option>
              <option value="zdce">Zero-DCE</option>
              <option value="none">ללא</option>
            </select>
          </div>
        </div>

        <!-- Row 2: edit tools + guided + smooth + zoom -->
        <div style="display:flex;gap:6px;margin-bottom:10px;align-items:center;flex-wrap:wrap;">
          <button onclick="undoPoint()" title="בטל נקודה אחרונה" style="padding:5px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">↩</button>
          <button id="roi-btn" onclick="toggleRoiMode()" title="סמן אזור ריבועי — זיהוי אוטומטי יפעל רק בתוכו" style="padding:5px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">□ ROI</button>
          <button id="silhouette-btn" onclick="toggleSilhouette()" title="הצג/הסתר סילואט כרקע" style="padding:5px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">🎭 סילואט</button>
          <button id="bgsample-btn" onclick="toggleBgSampleMode()" title="לחץ על אזור רקע בתמונה — המערכת תלמד את הטקסטורה ותסיר אותו מהמתאר" style="padding:5px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">🔬 רקע</button>
          <button onclick="clearContour()" style="padding:5px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">🗑 נקה</button>
          <div style="flex:1;"></div>
          <span style="font-size:11px;color:var(--muted);">זום:</span>
          <button onclick="zoomBy(1.3)" style="width:26px;height:26px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;">+</button>
          <button onclick="zoomBy(0.77)" style="width:26px;height:26px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;">−</button>
          <button onclick="resetZoom()" style="padding:5px 10px;border-radius:6px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">⊙</button>
          <span id="zoom-pct" style="font-family:'Fira Code',monospace;font-size:11px;color:var(--muted);width:36px;">100%</span>
        </div>

        <div style="background:var(--bg);border-radius:12px;overflow:hidden;margin-bottom:10px;display:flex;justify-content:center;align-items:center;">
          <canvas id="contour-canvas" style="max-width:100%;max-height:calc(100vh - 280px);min-height:320px;cursor:crosshair;touch-action:none;display:block;"></canvas>
        </div>

        <div id="contour-info" style="font-size:13px;color:var(--muted);margin-bottom:20px;min-height:18px;font-family:'Fira Code',monospace;"></div>

        <div style="display:flex;justify-content:space-between;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 5: Contour Review + Dimensions ─── -->
      <section class="panel" data-panel="5" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">סקירת מתארים ומידות</h2>
        <p style="color:var(--muted);margin:0 0 20px;font-size:14px;">מידות האובייקט מחושבות מהמתארים וקנה המידה. בדוק שהכל נכון לפני הציור הסופי.</p>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;">
          {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
            <div>
              <div style="font-size:11px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">{label}</div>
              <div style="background:var(--bg);border-radius:10px;overflow:hidden;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;">
                <canvas id={`rev-canvas-${v}`} style="max-width:100%;max-height:100%;"></canvas>
              </div>
            </div>
          ))}
        </div>

        <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:16px;">
          <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;margin-bottom:14px;">מידות האובייקט</div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
            {[['dim-W','רוחב (W)','פנים ← → פנים'],['dim-H','גובה (H)','פנים ↑ ↓ פנים'],['dim-D','עומק (D)','צד ← → צד']].map(([id,label,sub]) => (
              <div style="background:var(--bg);border-radius:10px;padding:14px;text-align:center;">
                <div style="font-size:11px;color:var(--muted);margin-bottom:6px;">{label}</div>
                <div id={id} style="font-size:26px;font-weight:700;font-family:'Fira Code',monospace;color:var(--subtle);">—</div>
                <div style="font-size:11px;color:var(--border);margin-top:2px;">מ"מ</div>
                <div style="font-size:10px;color:var(--border);margin-top:4px;">{sub}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Scale Cross-Validation (Bundle Adjustment simplified) -->
        <div id="scale-xval" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:24px;display:none;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;">אימות קנה מידה בין מבטים</span>
            <span id="xval-badge" style="font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;"></span>
          </div>
          <div id="xval-rows" style="display:flex;flex-direction:column;gap:6px;font-size:12px;font-family:'Fira Code',monospace;"></div>
          <div id="xval-suggestion" style="margin-top:10px;font-size:12px;color:var(--muted);"></div>
        </div>

        <div style="display:flex;justify-content:space-between;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 6: Visual Hull ─── -->
      <section class="panel" data-panel="6" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">שחזור 3D</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">Visual Hull מהמתארים. גרור לסיבוב, גלגל לזום.</p>

        <div style="background:#F8FAFC;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px;">
          <canvas id="hull-canvas" style="width:100%;display:block;cursor:grab;"></canvas>
        </div>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;">
          {[['W','רוחב'],['H','גובה'],['D','עומק']].map(([k,label]) => (
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;text-align:center;">
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px;">{label}</div>
              <div id={`hull-dim-${k}`} style="font-size:22px;font-weight:700;font-family:'Fira Code',monospace;color:var(--teal-light);">—</div>
              <div style="font-size:11px;color:var(--border);">מ"מ</div>
            </div>
          ))}
        </div>

        <div style="display:flex;gap:8px;margin-bottom:12px;align-items:center;">
          <button onclick="resetHullView()" style="padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">⊙ איפוס</button>
          <button onclick="toggleHullGrid()" id="hull-grid-btn" style="padding:6px 14px;border-radius:8px;border:1px solid var(--teal);background:rgba(13,148,136,.15);color:var(--teal-light);font-size:12px;cursor:pointer;">רשת ✓</button>
          <span style="font-size:11px;color:var(--muted);margin-right:auto;">הגבהה:</span>
          <input id="hull-el" type="range" min="-30" max="70" value="22" style="width:80px;accent-color:#0D9488;" oninput="hull.el=parseInt(this.value);renderVisualHull();" />
        </div>

        <div style="display:flex;justify-content:space-between;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 7: Vectorization ─── -->
      <section class="panel" data-panel="7" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">וקטוריזציה</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">זיהוי קטעים ישרים (ירוק) וקשתות (כתום) במתאר.</p>

        <div style="display:flex;gap:8px;margin-bottom:14px;">
          {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
            <button class="vec-tab" data-v={v} onclick={`setVecView('${v}')`}
              style="padding:6px 18px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:13px;cursor:pointer;">{label}</button>
          ))}
        </div>

        <div style="display:grid;grid-template-columns:1fr 230px;gap:14px;align-items:start;">
          <div style="background:var(--bg);border-radius:12px;overflow:hidden;">
            <canvas id="vec-canvas" style="max-width:100%;display:block;"></canvas>
          </div>
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;">
            <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">גאומטריה</div>
            <div id="vec-stats" style="font-size:12px;color:var(--muted);">—</div>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border);">
              <div style="font-size:11px;color:var(--muted);margin-bottom:6px;">סף פישוט:</div>
              <input id="vec-eps" type="range" min="1" max="20" value="5" oninput="renderVectorize()" style="width:100%;" />
              <div id="vec-eps-val" style="font-size:11px;color:var(--teal-light);text-align:center;margin-top:4px;font-family:'Fira Code',monospace;">5 px</div>
            </div>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border);">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;">תיאור צורה</div>
                <button onclick="computeShapeDescriptors()" style="padding:3px 10px;border-radius:6px;border:1px solid #7C3AED;background:rgba(124,58,237,.1);color:#A78BFA;font-size:11px;cursor:pointer;font-weight:600;">🔷 חשב</button>
              </div>
              <div id="shape-desc" style="font-size:11px;color:var(--muted);">לחץ "חשב" לניתוח צורה</div>
              <canvas id="radial-sig-canvas" width="200" height="56" style="width:100%;margin-top:8px;border-radius:6px;display:none;"></canvas>
            </div>
          </div>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:24px;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 8: Dimensions ─── -->
      <section class="panel" data-panel="8" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">קווי מידה</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">מידות אוטומטיות מה-bounding box של כל מתאר. לחץ על מידה לעריכה.</p>

        <div style="display:flex;gap:8px;margin-bottom:14px;">
          {[['front','פנים'],['side','צד'],['top','על']].map(([v,label]) => (
            <button class="dim-tab" data-v={v} onclick={`setDimView('${v}')`}
              style="padding:6px 18px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:13px;cursor:pointer;">{label}</button>
          ))}
        </div>

        <div style="display:grid;grid-template-columns:1fr 260px;gap:16px;align-items:start;">
          <div style="background:var(--bg);border-radius:12px;overflow:hidden;display:flex;justify-content:center;">
            <canvas id="dim-canvas" style="max-width:100%;max-height:420px;"></canvas>
          </div>

          <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;">
            <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;margin-bottom:12px;">מידות (מ"מ)</div>
            <div id="dim-list" style="font-family:'Fira Code',monospace;font-size:13px;color:var(--text);"></div>
          </div>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:24px;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">המשך →</button>
        </div>
      </section>

      <!-- ─── STEP 9: Drawing Layout ─── -->
      <section class="panel" data-panel="9" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">פריסת ציור</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">סרטוט טכני לפי תקן — 3 מבטים אורתוגונליים עם קווי היטל.</p>

        <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px;flex-wrap:wrap;">
          <label style="font-size:13px;color:var(--subtle);">שם החלק:</label>
          <input id="part-name" type="text" placeholder="חלק מס' 1" value="חלק מס' 1"
            style="padding:6px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:13px;width:180px;" />
          <label style="font-size:13px;color:var(--subtle);">קנה מידה:</label>
          <select id="draw-scale" style="padding:6px 10px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:13px;">
            <option value="1">1:1</option><option value="2">1:2</option><option value="5">1:5</option><option value="10">1:10</option>
          </select>
          <button onclick="renderLayout()" style="padding:6px 16px;border-radius:8px;background:var(--teal);color:white;border:none;font-size:13px;cursor:pointer;">רענן</button>
        </div>

        <div style="background:#fff;border-radius:12px;overflow:hidden;display:flex;justify-content:center;box-shadow:0 0 0 1px var(--border);">
          <canvas id="layout-canvas" style="max-width:100%;display:block;"></canvas>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:20px;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← חזור</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">המשך → ייצוא</button>
        </div>
      </section>

      <!-- ─── STEP 10: Export ─── -->
      <section class="panel" data-panel="10" style="padding:40px;display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">ייצוא</h2>
        <p style="color:var(--muted);margin:0 0 28px;font-size:14px;">הורד את הסרטוט הטכני בפורמט שתבחר.</p>

        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:32px;">
          <button onclick="exportDXF()" style="padding:24px 16px;border-radius:14px;border:1px solid var(--teal);background:rgba(13,148,136,.08);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:10px;transition:border-color .2s;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
              <line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/>
            </svg>
            <span style="font-size:15px;font-weight:700;color:var(--teal-light);">DXF</span>
            <span style="font-size:12px;color:var(--muted);">AutoCAD / LibreCAD</span>
          </button>

          <button onclick="exportSVG()" style="padding:24px 16px;border-radius:14px;border:1px solid var(--border);background:var(--surface);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:10px;transition:border-color .2s;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="1.5">
              <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>
            </svg>
            <span style="font-size:15px;font-weight:700;color:var(--text);">SVG</span>
