  document.querySelector(`.upload-zone[data-view="${v}"]`).style.borderColor = 'var(--teal)';
  document.querySelector(`.upload-zone[data-view="${v}"]`).style.borderStyle = 'solid';
  const cropBtn = document.getElementById(`crop-${v}`);
  if (cropBtn) cropBtn.style.display = 'flex';
