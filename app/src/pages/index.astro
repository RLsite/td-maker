---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="TD Maker">
<div id="app" style="height:100vh;display:flex;flex-direction:column;overflow:hidden;">

  <!-- ══════════════ HEADER ══════════════ -->
  <header style="height:52px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 14px;gap:10px;flex-shrink:0;">
    <button id="sidebar-toggle" onclick="toggleSidebar()" title="Show/Hide Menu" style="width:32px;height:32px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2.5" style="flex-shrink:0;">
      <rect x="3" y="3" width="18" height="18" rx="2"/>
      <line x1="3" y1="9" x2="21" y2="9"/>
      <line x1="9" y1="3" x2="9" y2="21"/>
    </svg>
    <span style="font-family:'Fira Code',monospace;font-weight:700;font-size:16px;color:var(--teal-light);white-space:nowrap;">TD Maker</span>
    <div style="flex:1;min-width:0;"></div>
    <button onclick="prevStep()" id="hdr-prev" title="Previous step" style="width:28px;height:28px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;line-height:1;">‹</button>
    <span id="step-label" class="header-step-label" style="font-size:12px;color:var(--muted);white-space:nowrap;">Step 1 of 10</span>
    <div id="progress-bar-wrap" style="width:100px;height:5px;background:var(--border);border-radius:999px;overflow:hidden;flex-shrink:0;">
      <div id="progress-bar" style="height:100%;width:10%;background:var(--teal);border-radius:999px;transition:width 0.35s;"></div>
    </div>
    <button onclick="nextStep()" id="hdr-next" title="Next step" style="width:28px;height:28px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:15px;line-height:1;">›</button>
    <button onclick="printCalibration()" title="Print Calibration Sheet" class="hdr-btn" style="font-size:12px;padding:5px 10px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;display:flex;align-items:center;gap:5px;white-space:nowrap;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      Calibrate
    </button>
    <button onclick="newProject()" class="hdr-btn" style="font-size:12px;padding:5px 10px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);cursor:pointer;white-space:nowrap;">+ New</button>
  </header>

  <!-- ══════════════ CAMERA MODAL ══════════════ -->
  <div id="camera-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:100;flex-direction:column;align-items:center;justify-content:center;gap:16px;">
    <video id="camera-video" autoplay playsinline style="display:none;"></video>
    <canvas id="camera-canvas" style="border-radius:12px;background:#000;max-width:90vw;max-height:65vh;"></canvas>
    <div style="display:flex;gap:12px;align-items:center;">
      <button onclick="rotateCamera()" title="Rotate 90°" style="padding:10px 18px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:22px;border:1px solid var(--border);cursor:pointer;line-height:1;">↻</button>
      <button onclick="capturePhoto()" style="padding:12px 32px;border-radius:10px;background:var(--teal);color:white;font-size:15px;font-weight:700;border:none;cursor:pointer;">Capture</button>
      <button onclick="closeCamera()" style="padding:12px 24px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:14px;border:1px solid var(--border);cursor:pointer;">Cancel</button>
    </div>
  </div>

  <!-- ══════════════ CROP MODAL ══════════════ -->
  <div id="crop-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:100;flex-direction:column;align-items:center;justify-content:center;gap:14px;">
    <div style="font-size:12px;color:var(--muted);">Drag to move • Corners to resize • Click outside area for new crop</div>
    <canvas id="crop-canvas" style="border-radius:8px;cursor:crosshair;max-width:92vw;max-height:72vh;display:block;"></canvas>
    <div style="display:flex;gap:10px;align-items:center;">
      <button onclick="applyCrop()" style="padding:10px 28px;border-radius:10px;background:var(--teal);color:white;font-size:14px;font-weight:700;border:none;cursor:pointer;">Crop ✓</button>
      <button onclick="_autoCropDetect()" style="padding:10px 18px;border-radius:10px;background:rgba(13,148,136,.15);color:var(--teal-light);font-size:13px;font-weight:600;border:1px solid rgba(13,148,136,.5);cursor:pointer;">✦ Auto Detect</button>
      <button onclick="resetCropRect()" style="padding:10px 18px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:13px;border:1px solid var(--border);cursor:pointer;">Reset</button>
      <button onclick="closeCrop()" style="padding:10px 18px;border-radius:10px;background:var(--surface);color:var(--subtle);font-size:13px;border:1px solid var(--border);cursor:pointer;">Cancel</button>
    </div>
  </div>

  <!-- ══════════════ BODY ══════════════ -->
  <div style="display:flex;flex:1;overflow:hidden;">

    <!-- ── SIDEBAR ── -->
    <aside id="sidebar" style="width:220px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);overflow-y:auto;overflow-x:hidden;padding:10px;transition:width 0.22s ease,padding 0.22s ease;"></aside>

    <!-- ── MAIN ── -->
    <main id="main" style="flex:1;overflow-y:auto;min-width:0;">

      <!-- ─── STEP 1: Upload ─── -->
      <section class="panel" data-panel="1" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Upload Images</h2>
        <p style="color:var(--muted);margin:0 0 28px;font-size:14px;">Upload 3 photos — front, side, top. Place a ruler in each image.</p>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:24px;" class="upload-grid-3">
          {[['front','Front'],['side','Side'],['top','Top']].map(([v,label]) => (
            <div>
              <div style="font-size:11px;font-weight:700;letter-spacing:.07em;color:var(--subtle);margin-bottom:8px;text-transform:uppercase;">{label}</div>
              <div class="upload-zone" data-view={v} onclick={`triggerUpload('${v}')`}
                style="height:200px;border:2px dashed var(--border);border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;background:var(--bg);transition:border-color .2s;">
                <img id={`preview-${v}`} style="display:none;width:100%;height:100%;object-fit:contain;position:absolute;inset:0;" />
                <button id={`delete-${v}`} onclick={`event.stopPropagation();deleteImg('${v}')`}
                  style="display:none;position:absolute;top:6px;right:6px;z-index:10;width:26px;height:26px;border-radius:50%;border:none;background:rgba(239,68,68,.85);color:white;font-size:15px;line-height:1;cursor:pointer;align-items:center;justify-content:center;">✕</button>
                <button id={`crop-${v}`} onclick={`event.stopPropagation();openCrop('${v}')`}
                  style="display:none;position:absolute;top:6px;left:6px;z-index:10;padding:3px 9px;border-radius:6px;border:none;background:rgba(13,148,136,.88);color:white;font-size:11px;font-weight:700;cursor:pointer;">Crop</button>
                <button id={`autocrop-${v}`} onclick={`event.stopPropagation();autoCropView('${v}')`}
                  style="display:none;position:absolute;top:34px;left:6px;z-index:10;padding:3px 9px;border-radius:6px;border:none;background:rgba(99,102,241,.88);color:white;font-size:11px;font-weight:700;cursor:pointer;">✦ Auto</button>
                <div id={`placeholder-${v}`} style="display:flex;flex-direction:column;align-items:center;gap:10px;color:var(--border);pointer-events:none;">
                  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                    <circle cx="12" cy="13" r="4"/>
                  </svg>
                  <span style="font-size:13px;">Click to upload</span>
                </div>
              </div>
              <div style="display:flex;gap:6px;margin-top:7px;">
                <input type="file" id={`input-${v}`} accept="image/*" style="display:none" onchange={`handleUpload(event,'${v}')`} />
                <button onclick={`triggerUpload('${v}')`} style="flex:1;padding:5px 0;border-radius:7px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">File</button>
                <button onclick={`openCamera('${v}')`} style="flex:1;padding:5px 0;border-radius:7px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:4px;">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                  Camera
                </button>
              </div>
            </div>
          ))}
        </div>

        <!-- תמונה איזומטרית — אופציונלי -->
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;gap:16px;">
          <div class="upload-zone" data-view="iso" onclick="triggerUpload('iso')"
            style="width:130px;height:90px;border:2px dashed var(--border);border-radius:10px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;position:relative;overflow:hidden;background:var(--bg);">
            <img id="preview-iso" style="display:none;width:100%;height:100%;object-fit:contain;position:absolute;inset:0;" />
            <button id="crop-iso" onclick="event.stopPropagation();openCrop('iso')"
              style="display:none;position:absolute;top:4px;left:4px;z-index:10;padding:2px 7px;border-radius:5px;border:none;background:rgba(13,148,136,.88);color:white;font-size:10px;font-weight:700;cursor:pointer;">Crop</button>
            <div id="placeholder-iso" style="display:flex;flex-direction:column;align-items:center;gap:5px;color:var(--border);pointer-events:none;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
              <span style="font-size:11px;">Upload</span>
            </div>
          </div>
          <input type="file" id="input-iso" accept="image/*" style="display:none" onchange="handleUpload(event,'iso')" />
          <div>
            <div style="font-size:12px;font-weight:700;color:var(--teal-light);margin-bottom:4px;">Isometric Image <span style="font-weight:400;color:var(--muted);font-size:11px;">(optional)</span></div>
            <div style="font-size:12px;color:var(--muted);line-height:1.6;">An image showing multiple views — front + side + top at once.<br/>Improves 3D reconstruction accuracy.</div>
            <div style="display:flex;gap:6px;margin-top:8px;">
              <button onclick="triggerUpload('iso')" style="padding:4px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:11px;cursor:pointer;">File</button>
              <button onclick="openCamera('iso')" style="padding:4px 12px;border-radius:6px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:11px;cursor:pointer;display:flex;align-items:center;gap:4px;">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                Camera
              </button>
            </div>
          </div>
        </div>

        <div id="upload-status" style="font-size:13px;color:var(--muted);min-height:20px;margin-bottom:12px;"></div>

        <!-- Quick Analysis result — appears automatically when all 3 images are uploaded -->
        <div id="quick-analysis" style="display:none;background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px 20px;margin-bottom:16px;"></div>

        <div style="display:flex;justify-content:flex-end;">
          <button id="step1-next" onclick="nextStep()" disabled
            style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--border);color:var(--muted);cursor:not-allowed;transition:all .2s;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 4: Scale ─── -->
      <section class="panel" data-panel="4" style="display:none;height:100%;box-sizing:border-box;overflow:hidden;flex-direction:column;">

        <!-- Header row -->
        <div style="flex-shrink:0;">
          <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Scale</h2>
          <p style="color:var(--muted);margin:0 0 14px;font-size:14px;">Click two points on the ruler, enter the distance in mm, then click <strong style="color:var(--text);">Add</strong>.</p>

          <div class="view-tabs-row" style="display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap;">
            {[['front','Front'],['side','Side'],['top','Top']].map(([v,label]) => (
              <button class="scale-tab view-tab" data-v={v} onclick={`setScaleView('${v}')`}>{label}<span class="vtab-badge" id={`sctab-badge-${v}`}></span></button>
            ))}
            <button onclick="autoDetectScale()" style="padding:4px 14px;border-radius:7px;border:1px solid rgba(13,148,136,.5);background:rgba(13,148,136,.12);color:var(--teal-light);font-size:13px;font-weight:600;cursor:pointer;">🔍 Auto Detect</button>
            <span id="ruler-detect-info" style="font-size:11px;color:var(--muted);flex:1;"></span>
            <button id="scale-float-btn" onclick="toggleFloatScaleCanvas()" title="Float image window"
              style="padding:5px 10px;border-radius:8px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;display:flex;align-items:center;gap:4px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/>
              </svg>Window
            </button>
          </div>
        </div>

        <!-- Main area: canvas top, measurements table bottom -->
        <div style="display:flex;flex-direction:column;gap:8px;flex:1;min-height:0;">

          <!-- Canvas — fills remaining space, zoom overlay inside -->
          <div id="scale-canvas-wrap" style="flex:1;min-height:0;background:var(--bg);border-radius:12px;overflow:hidden;position:relative;display:flex;justify-content:center;align-items:center;">
            <canvas id="scale-canvas" style="cursor:crosshair;"></canvas>
            <!-- Status overlay (bottom-left) -->
            <div style="position:absolute;bottom:10px;left:12px;pointer-events:none;">
              <span id="scale-pts-info" style="font-size:11px;color:rgba(148,163,184,.85);font-family:'Fira Code',monospace;background:rgba(15,23,42,.7);padding:3px 8px;border-radius:6px;">Click point 1 on the ruler</span>
            </div>
            <!-- Zoom controls overlay (bottom-right) -->
            <div style="position:absolute;bottom:10px;right:10px;display:flex;align-items:center;gap:4px;">
              <button onclick="scaleZoomBy(1.3)" style="width:22px;height:22px;border-radius:5px;border:1px solid rgba(100,116,139,.4);background:rgba(15,23,42,.7);color:#94A3B8;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">+</button>
              <button onclick="scaleZoomBy(0.77)" style="width:22px;height:22px;border-radius:5px;border:1px solid rgba(100,116,139,.4);background:rgba(15,23,42,.7);color:#94A3B8;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">−</button>
              <button onclick="resetScaleZoom()" style="width:22px;height:22px;border-radius:5px;border:1px solid rgba(100,116,139,.4);background:rgba(15,23,42,.7);color:#94A3B8;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;">⊙</button>
              <span id="scale-zoom-pct" style="font-family:'Fira Code',monospace;font-size:10px;color:rgba(148,163,184,.7);background:rgba(15,23,42,.7);padding:2px 5px;border-radius:4px;">100%</span>
            </div>
          </div>

          <!-- Measurements table — compact strip below canvas -->
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:10px 14px;flex-shrink:0;">

            <!-- Header row: label | view | mm input | Add | separator | average | all-views -->
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap;">
              <span style="font-size:11px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;">Measurements</span>
              <span id="meas-view-label" style="font-size:11px;color:var(--teal-light);font-weight:600;"></span>
              <div style="flex:1;"></div>
              <input id="mm-input" type="number" min="0.1" step="0.1" placeholder="mm"
                style="width:68px;padding:4px 8px;border-radius:7px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:12px;font-family:'Fira Code',monospace;text-align:center;" />
              <span style="font-size:11px;color:var(--muted);">mm</span>
              <button onclick="addMeasurement()" style="padding:4px 12px;border-radius:7px;background:var(--teal);color:white;border:none;font-size:12px;font-weight:600;cursor:pointer;">+ Add</button>
              <span style="width:1px;height:16px;background:var(--border);flex-shrink:0;margin:0 4px;"></span>
              <span style="font-size:11px;color:var(--muted);">Avg:</span>
              <span id="scale-avg" style="font-size:15px;font-weight:700;font-family:'Fira Code',monospace;color:var(--subtle);">—</span>
              <span style="font-size:10px;color:var(--muted);">px/mm</span>
              <span style="width:1px;height:16px;background:var(--border);flex-shrink:0;margin:0 4px;"></span>
              {[['front','F'],['side','S'],['top','T']].map(([v,label]) => (
                <div style="display:flex;flex-direction:column;align-items:center;min-width:32px;">
                  <span style="font-size:9px;color:var(--muted);">{label}</span>
                  <span id={`scale-${v}`} style="font-size:12px;font-weight:700;font-family:'Fira Code',monospace;color:var(--subtle);">—</span>
                </div>
              ))}
            </div>

            <!-- Measurement rows -->
            <div id="meas-list" style="max-height:80px;overflow-y:auto;">
              <div style="font-size:12px;color:var(--border);text-align:center;padding:8px 0;">No measurements yet</div>
            </div>

          </div>

        </div>

        <!-- Cross-view model bar -->
        <div id="scale-model-bar" style="flex-shrink:0;margin-top:6px;"></div>

        <div style="display:flex;justify-content:space-between;flex-shrink:0;margin-top:10px;">
          <button onclick="prevStep()" style="padding:8px 20px;border-radius:10px;font-size:13px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button id="step4-next" onclick="nextStep()" disabled
            style="padding:8px 24px;border-radius:10px;font-size:13px;font-weight:600;border:none;background:var(--border);color:var(--muted);cursor:not-allowed;transition:all .2s;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 3: Contour (was 4) moved before scale ─── -->
      <!-- ─── STEP 2: Segmentation ─── -->
      <section class="panel" data-panel="2" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Background Separation</h2>
        <p style="color:var(--muted);margin:0 0 20px;font-size:14px;">Adjust the threshold to get a clean silhouette mask of the object.</p>

        <div class="seg-tabs-row view-tabs-row" style="display:flex;gap:8px;margin-bottom:12px;">
          {[['top','Top'],['front','Front'],['side','Side']].map(([v,label]) => (
            <button class="seg-tab view-tab" data-v={v} onclick={`setSegView('${v}')`}>{label}<span class="vtab-badge" id={`stab-badge-${v}`}></span></button>
          ))}
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px;">
          <div style="position:relative;">
            <div style="font-size:12px;color:var(--muted);margin-bottom:6px;">Source</div>
            <canvas id="seg-src" style="width:100%;border-radius:8px;cursor:crosshair;"></canvas>
            <!-- calibration corner overlay -->
            <canvas id="seg-cal-overlay" style="position:absolute;top:22px;left:0;width:100%;height:calc(100% - 22px);border-radius:8px;pointer-events:none;"></canvas>
          </div>
          <div>
            <div style="font-size:12px;color:var(--muted);margin-bottom:6px;">Silhouette</div>
            <canvas id="seg-out" style="width:100%;border-radius:8px;"></canvas>
          </div>
          <div>
            <div id="seg-computed-label" style="font-size:12px;color:var(--muted);margin-bottom:6px;">Computed</div>
            <canvas id="seg-computed" style="width:100%;border-radius:8px;background:rgba(13,148,136,.04);border:1px dashed rgba(13,148,136,.25);"></canvas>
          </div>
        </div>
        <!-- calibration background status bar -->
        <div id="cal-bg-bar" style="display:none;align-items:center;gap:8px;background:rgba(124,58,237,.12);border:1px solid #7C3AED;border-radius:8px;padding:7px 12px;margin-bottom:8px;font-size:12px;color:#A78BFA;">
          <span>📐</span>
          <span id="cal-bg-msg">Click the 4 grid corners in the image (UL → UR → DR → DL)</span>
          <button onclick="calBgCancel()" style="margin-right:auto;padding:2px 8px;border-radius:5px;border:1px solid #7C3AED;background:transparent;color:#A78BFA;font-size:11px;cursor:pointer;">Cancel</button>
        </div>

        <div style="display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;">
          <button onclick="segAutoOtsu()" style="padding:5px 12px;border-radius:8px;border:1px solid var(--teal);background:rgba(13,148,136,.1);color:var(--teal-light);font-size:12px;cursor:pointer;font-weight:600;">✦ Otsu Auto</button>
          <button onclick="segAutoSauvola()" title="Sauvola adaptive threshold — beats Otsu for images with shadows or uneven lighting (skimage.filters.threshold_sauvola)" style="padding:5px 12px;border-radius:8px;border:1px solid var(--teal);background:rgba(13,148,136,.1);color:var(--teal-light);font-size:12px;cursor:pointer;font-weight:600;">⊞ Sauvola</button>
          <button onclick="setSegMode('dark')" id="seg-mode-dark" style="padding:5px 12px;border-radius:8px;border:1px solid var(--teal);background:rgba(13,148,136,.15);color:var(--teal-light);font-size:12px;cursor:pointer;">● Dark Object</button>
          <button onclick="setSegMode('light')" id="seg-mode-light" style="padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">○ Light Object</button>
          <button onclick="segMorphClean()" style="padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">⬜ Clean Noise</button>
          <button onclick="segFillHoles()" title="Fill enclosed holes in segmentation mask (skimage.morphology.remove_small_holes)" style="padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">⬚ Fill Holes</button>
          <button onclick="gmmSegment()" title="GMM Color Segmentation — GrabCut simplified (Rother 2004)" style="padding:5px 12px;border-radius:8px;border:1px solid #7C3AED;background:rgba(124,58,237,.1);color:#A78BFA;font-size:12px;cursor:pointer;font-weight:600;">🧩 GMM</button>
          <button onclick="startCalBgMode()" title="Calibration background subtraction — click 4 grid corners" style="padding:5px 12px;border-radius:8px;border:1px solid #F59E0B;background:rgba(245,158,11,.1);color:#FCD34D;font-size:12px;cursor:pointer;font-weight:600;">📐 Cal Background</button>
          <button id="seg-save-btn" onclick="saveSegSettings()" title="Save threshold and mode settings for all views" style="padding:5px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">💾 Save Settings</button>
        </div>
        <div style="display:flex;align-items:center;gap:14px;margin-bottom:10px;">
          <label style="font-size:13px;color:var(--subtle);width:60px;">Threshold:</label>
          <input id="seg-slider" type="range" min="30" max="240" value="120" oninput="applyThreshold()"
            style="flex:1;" />
          <span id="seg-val" style="font-family:'Fira Code',monospace;font-size:13px;color:var(--teal-light);width:36px;">120</span>
        </div>

        <!-- Reliability score bar — per-view + per-region quality after segmentation -->
        <div id="seg-score-bar" style="margin-bottom:10px;"></div>

        <!-- Cross-view model bar — updates live as threshold changes -->
        <div id="seg-model-bar" style="display:none;align-items:center;flex-wrap:wrap;gap:4px;padding:6px 12px;margin-bottom:18px;background:rgba(13,148,136,.06);border:1px solid rgba(13,148,136,.2);border-radius:8px;min-height:32px;"></div>

        <!-- Depth estimation row -->
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;padding:8px 12px;background:rgba(13,148,136,.04);border:1px solid rgba(13,148,136,.15);border-radius:10px;">
          <button onclick="computeDepthMap(S.segView)"
            style="padding:5px 14px;border-radius:8px;font-size:12px;font-weight:600;border:1px solid rgba(13,148,136,.5);background:rgba(13,148,136,.12);color:#2dd4bf;cursor:pointer;white-space:nowrap;">
            🔬 Depth Map
          </button>
          <span id="depth-status" style="font-size:11px;color:#94a3b8;flex:1;">Not computed — click to run Depth-Anything v2</span>
        </div>

        <div style="display:flex;justify-content:space-between;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 3: Contour ─── -->
      <section class="panel" data-panel="3" style="display:none;height:100%;box-sizing:border-box;overflow:hidden;flex-direction:column;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;flex-shrink:0;">Contour Drawing</h2>
        <p style="color:var(--muted);margin:0 0 12px;font-size:14px;flex-shrink:0;">Click on object boundaries, or use auto-detect. Scroll to zoom, drag to pan.</p>

        <!-- Row 1: view tabs -->
        <div class="view-tabs-row" style="display:flex;gap:8px;margin-bottom:6px;">
          {[['front','Front'],['side','Side'],['top','Top']].map(([v,label]) => (
            <button class="contour-tab view-tab" data-v={v} onclick={`setContourView('${v}')`}>
              {label}<span class="vtab-badge" id={`ctab-badge-${v}`}></span>
            </button>
          ))}
        </div>

        <!-- Row 2: Auto Detection -->
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;padding:5px 10px;background:rgba(13,148,136,.07);border:1px solid rgba(13,148,136,.28);border-radius:8px;">
          <button onclick="autoDetectContour()" style="padding:4px 14px;border-radius:7px;border:1px solid rgba(13,148,136,.5);background:rgba(13,148,136,.12);color:var(--teal-light);font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;">✦ Auto Detect</button>
          <span style="width:1px;height:16px;background:rgba(13,148,136,.3);flex-shrink:0;"></span>
          <span style="font-size:11px;color:var(--muted);">Points:</span>
          <select id="pts-count-sel" onchange="resampleContour(+this.value)"
            title="Contour point count"
            style="padding:2px 6px;border-radius:6px;border:1px solid var(--border);background:var(--bg);color:var(--teal-light);font-size:12px;font-weight:600;cursor:pointer;min-width:54px;">
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="40">40</option>
            <option value="50" selected>50</option>
            <option value="60">60</option>
            <option value="100">100</option>
            <option value="200">200</option>
          </select>
        </div>

        <!-- Row 3: Tools -->
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px;flex-shrink:0;">
          <div style="display:flex;align-items:center;gap:5px;padding:4px 10px;background:rgba(245,158,11,.06);border:1px solid rgba(245,158,11,.28);border-radius:8px;">
            <span style="font-size:10px;font-weight:700;letter-spacing:.07em;color:#FCD34D;text-transform:uppercase;white-space:nowrap;">Manual</span>
            <button id="roi-btn" onclick="toggleRoiMode()" title="Draw a rectangle — Auto Detect applies only inside" style="padding:4px 9px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">□ ROI</button>
            <button id="silhouette-btn" onclick="toggleSilhouette()" title="Default: Computed silhouette. Toggle to show original photo." style="padding:4px 9px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">📷 Photo</button>
            <button id="bgsample-btn" onclick="toggleBgSampleMode()" title="Click a background area to exclude its colour" style="padding:4px 9px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">🔬 Background</button>
            <button id="add-hole-btn" onclick="addHole()" title="Add a hole contour inside the outer contour" style="padding:4px 9px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;opacity:0.4;pointer-events:none;">🕳 Hole</button>
            <span id="active-contour-badge" style="display:none;padding:2px 8px;border-radius:12px;font-size:10px;font-weight:700;background:rgba(13,148,136,.2);border:1px solid rgba(13,148,136,.5);color:#14B8A6;white-space:nowrap;"></span>
          </div>
          <span style="width:1px;height:20px;background:var(--border);flex-shrink:0;"></span>
          <button onclick="undoPoint()" title="Undo last point" style="padding:4px 9px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">↩ Undo</button>
          <button onclick="clearContour()" title="Clear contour" style="padding:4px 9px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;">🗑 Clear</button>
          <span style="width:1px;height:20px;background:var(--border);flex-shrink:0;"></span>
          <button id="float-btn" onclick="toggleFloatCanvas()" title="Open floating image window" style="padding:4px 9px;border-radius:7px;border:1px solid var(--border);background:transparent;color:var(--subtle);font-size:12px;cursor:pointer;display:flex;align-items:center;gap:4px;">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><polyline points="9 3 3 3 3 9"/><polyline points="15 21 21 21 21 15"/><line x1="3" y1="3" x2="10" y2="10"/><line x1="21" y1="21" x2="14" y2="14"/></svg>
            Window
          </button>
        </div>

        <div id="contour-canvas-wrap" style="background:var(--bg);border-radius:12px;overflow:hidden;margin-bottom:6px;display:flex;justify-content:center;align-items:center;flex:1;min-height:0;position:relative;">
          <canvas id="contour-canvas" style="display:block;cursor:crosshair;touch-action:none;"></canvas>
          <!-- Contour selector overlay (top-left) — shown only when holes exist -->
          <div id="contour-select-overlay" style="display:none;position:absolute;top:10px;left:10px;flex-direction:column;gap:4px;z-index:10;pointer-events:auto;"></div>
          <!-- Zoom controls overlay (bottom-right, same pattern as Scale) -->
          <div style="position:absolute;bottom:10px;right:10px;display:flex;align-items:center;gap:4px;">
            <button onclick="zoomBy(1.3)" style="width:22px;height:22px;border-radius:5px;border:1px solid rgba(100,116,139,.4);background:rgba(15,23,42,.7);color:#94A3B8;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">+</button>
            <button onclick="zoomBy(0.77)" style="width:22px;height:22px;border-radius:5px;border:1px solid rgba(100,116,139,.4);background:rgba(15,23,42,.7);color:#94A3B8;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">−</button>
            <button onclick="resetZoom()" style="width:22px;height:22px;border-radius:5px;border:1px solid rgba(100,116,139,.4);background:rgba(15,23,42,.7);color:#94A3B8;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;">⊙</button>
            <span id="zoom-pct" style="font-family:'Fira Code',monospace;font-size:10px;color:rgba(148,163,184,.7);background:rgba(15,23,42,.7);padding:2px 5px;border-radius:4px;">100%</span>
          </div>
        </div>

        <div id="contour-info" style="font-size:12px;color:var(--muted);margin-bottom:4px;min-height:16px;font-family:'Fira Code',monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"></div>

        <!-- Cross-view model + detected dimensions bar -->
        <div id="model-bar" style="display:none;align-items:center;flex-wrap:wrap;gap:4px;padding:5px 12px;margin-bottom:6px;background:rgba(13,148,136,.06);border:1px solid rgba(13,148,136,.2);border-radius:8px;min-height:28px;flex-shrink:0;"></div>

        <div style="display:flex;justify-content:space-between;flex-shrink:0;">
          <button onclick="prevStep()" style="padding:8px 20px;border-radius:10px;font-size:13px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button onclick="nextStep()" style="padding:8px 24px;border-radius:10px;font-size:13px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 5: Contour Review + Dimensions ─── -->
      <section class="panel" data-panel="5" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Contour Review & Dimensions</h2>
        <p style="color:var(--muted);margin:0 0 20px;font-size:14px;">Object dimensions are calculated from the contours and scale. Verify everything before the final drawing.</p>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px;">
          {[['front','Front'],['side','Side'],['top','Top']].map(([v,label]) => (
            <div>
              <div style="font-size:11px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">{label}</div>
              <div style="background:var(--bg);border-radius:10px;overflow:hidden;aspect-ratio:4/3;display:flex;align-items:center;justify-content:center;">
                <canvas id={`rev-canvas-${v}`} style="max-width:100%;max-height:100%;"></canvas>
              </div>
            </div>
          ))}
        </div>

        <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;margin-bottom:16px;">
          <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;margin-bottom:14px;">Object Dimensions</div>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
            {[['dim-W','Width (W)','Front ← → Front'],['dim-H','Height (H)','Front ↑ ↓ Front'],['dim-D','Depth (D)','Side ← → Side']].map(([id,label,sub]) => (
              <div style="background:var(--bg);border-radius:10px;padding:14px;text-align:center;">
                <div style="font-size:11px;color:var(--muted);margin-bottom:6px;">{label}</div>
                <div id={id} style="font-size:26px;font-weight:700;font-family:'Fira Code',monospace;color:var(--subtle);">—</div>
                <div style="font-size:11px;color:var(--border);margin-top:2px;">mm</div>
                <div style="font-size:10px;color:var(--border);margin-top:4px;">{sub}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Reference Size Comparison -->
        <div id="ref-compare-card" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:16px;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
            <span style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;">Compare with Reference Object</span>
            <span id="ref-badge" style="font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;display:none;"></span>
          </div>
          <div style="display:grid;grid-template-columns:repeat(4,1fr) auto;gap:8px;align-items:end;margin-bottom:12px;">
            <div>
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px;">Reference Width W (mm)</div>
              <input id="ref-W" type="number" min="0.1" step="0.1" placeholder="—"
                style="width:100%;padding:7px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;font-family:'Fira Code',monospace;" />
            </div>
            <div>
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px;">Reference Height H (mm)</div>
              <input id="ref-H" type="number" min="0.1" step="0.1" placeholder="—"
                style="width:100%;padding:7px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;font-family:'Fira Code',monospace;" />
            </div>
            <div>
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px;">Reference Depth D (mm)</div>
              <input id="ref-D" type="number" min="0.1" step="0.1" placeholder="—"
                style="width:100%;padding:7px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;font-family:'Fira Code',monospace;" />
            </div>
            <div>
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px;">Tolerance (%)</div>
              <input id="ref-tol" type="number" min="0.5" max="50" step="0.5" value="10"
                style="width:100%;padding:7px 10px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:13px;font-family:'Fira Code',monospace;" />
            </div>
            <button onclick="compareWithReference()" style="padding:8px 16px;border-radius:8px;background:var(--teal);color:white;border:none;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;">Compare</button>
          </div>
          <div id="ref-rows" style="display:flex;flex-direction:column;gap:6px;"></div>
          <div id="ref-area" style="margin-top:8px;font-size:12px;color:var(--muted);font-family:'Fira Code',monospace;"></div>
        </div>

        <!-- Scale Cross-Validation (Bundle Adjustment simplified) -->
        <div id="scale-xval" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:24px;display:none;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
            <span style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;">Scale Cross-Validation Between Views</span>
            <span id="xval-badge" style="font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;"></span>
          </div>
          <div id="xval-rows" style="display:flex;flex-direction:column;gap:6px;font-size:12px;font-family:'Fira Code',monospace;"></div>
          <div id="xval-suggestion" style="margin-top:10px;font-size:12px;color:var(--muted);"></div>
        </div>

        <div style="display:flex;justify-content:space-between;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 6: Visual Hull ─── -->
      <section class="panel" data-panel="6" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">3D Reconstruction</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">Visual Hull from contours. Drag to rotate, scroll to zoom.</p>

        <div style="background:#F8FAFC;border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:14px;">
          <canvas id="hull-canvas" style="width:100%;display:block;cursor:grab;"></canvas>
        </div>

        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px;">
          {[['W','Width'],['H','Height'],['D','Depth']].map(([k,label]) => (
            <div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;text-align:center;">
              <div style="font-size:11px;color:var(--muted);margin-bottom:4px;">{label}</div>
              <div id={`hull-dim-${k}`} style="font-size:22px;font-weight:700;font-family:'Fira Code',monospace;color:var(--teal-light);">—</div>
              <div style="font-size:11px;color:var(--border);">mm</div>
            </div>
          ))}
        </div>

        <div style="display:flex;gap:8px;margin-bottom:12px;align-items:center;">
          <button onclick="resetHullView()" style="padding:6px 14px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--subtle);font-size:12px;cursor:pointer;">⊙ Reset</button>
          <button onclick="toggleHullGrid()" id="hull-grid-btn" style="padding:6px 14px;border-radius:8px;border:1px solid var(--teal);background:rgba(13,148,136,.15);color:var(--teal-light);font-size:12px;cursor:pointer;">Grid ✓</button>
          <span style="font-size:11px;color:var(--muted);margin-right:auto;">Elevation:</span>
          <input id="hull-el" type="range" min="-30" max="70" value="22" style="width:80px;accent-color:#0D9488;" oninput="hull.el=parseInt(this.value);renderVisualHull();" />
        </div>

        <div style="display:flex;justify-content:space-between;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 7: Vectorization ─── -->
      <section class="panel" data-panel="7" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Vectorization</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">Detect straight segments (green) and arcs (orange) in the contour.</p>

        <div class="view-tabs-row" style="display:flex;gap:8px;margin-bottom:14px;">
          {[['front','Front'],['side','Side'],['top','Top']].map(([v,label]) => (
            <button class="vec-tab view-tab" data-v={v} onclick={`setVecView('${v}')`}>{label}</button>
          ))}
        </div>

        <div style="display:grid;grid-template-columns:1fr 230px;gap:14px;align-items:start;">
          <div style="background:var(--bg);border-radius:12px;overflow:hidden;">
            <canvas id="vec-canvas" style="max-width:100%;display:block;"></canvas>
          </div>
          <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;">
            <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;margin-bottom:10px;">Geometry</div>
            <div id="vec-stats" style="font-size:12px;color:var(--muted);">—</div>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border);">
              <div style="font-size:11px;color:var(--muted);margin-bottom:6px;">Corner Sensitivity (angle threshold):</div>
              <input id="vec-eps" type="range" min="10" max="90" value="50" oninput="renderVectorize()" style="width:100%;" />
              <div id="vec-eps-val" style="font-size:11px;color:var(--teal-light);text-align:center;margin-top:4px;font-family:'Fira Code',monospace;">50°</div>
            </div>
            <div style="margin-top:14px;padding-top:12px;border-top:1px solid var(--border);">
              <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;letter-spacing:.05em;">Shape Description</div>
                <button onclick="computeShapeDescriptors()" style="padding:3px 10px;border-radius:6px;border:1px solid #7C3AED;background:rgba(124,58,237,.1);color:#A78BFA;font-size:11px;cursor:pointer;font-weight:600;">🔷 Compute</button>
              </div>
              <div id="shape-desc" style="font-size:11px;color:var(--muted);">Click "Compute" for shape analysis</div>
              <canvas id="radial-sig-canvas" width="200" height="56" style="width:100%;margin-top:8px;border-radius:6px;display:none;"></canvas>
            </div>
          </div>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:24px;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 8: Dimensions ─── -->
      <section class="panel" data-panel="8" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Dimension Lines</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">Automatic dimensions from the bounding box of each contour. Click a dimension to edit.</p>

        <div class="view-tabs-row" style="display:flex;gap:8px;margin-bottom:14px;">
          {[['front','Front'],['side','Side'],['top','Top']].map(([v,label]) => (
            <button class="dim-tab view-tab" data-v={v} onclick={`setDimView('${v}')`}>{label}</button>
          ))}
        </div>

        <div style="display:grid;grid-template-columns:1fr 260px;gap:16px;align-items:start;">
          <div style="background:var(--bg);border-radius:12px;overflow:hidden;display:flex;justify-content:center;">
            <canvas id="dim-canvas" style="max-width:100%;max-height:420px;"></canvas>
          </div>

          <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:14px;">
            <div style="font-size:12px;font-weight:700;color:var(--subtle);text-transform:uppercase;margin-bottom:12px;">Dimensions (mm)</div>
            <div id="dim-list" style="font-family:'Fira Code',monospace;font-size:13px;color:var(--text);"></div>
          </div>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:24px;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">Continue →</button>
        </div>
      </section>

      <!-- ─── STEP 9: Drawing Layout ─── -->
      <section class="panel" data-panel="9" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Drawing Layout</h2>
        <p style="color:var(--muted);margin:0 0 16px;font-size:14px;">Technical drawing to standard — 3 orthogonal views with projection lines.</p>

        <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px;flex-wrap:wrap;">
          <label style="font-size:13px;color:var(--subtle);">Part Name:</label>
          <input id="part-name" type="text" placeholder="Part No. 1" value="Part No. 1"
            style="padding:6px 12px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:13px;width:180px;" />
          <label style="font-size:13px;color:var(--subtle);">Scale:</label>
          <select id="draw-scale" style="padding:6px 10px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:13px;">
            <option value="1">1:1</option><option value="2">1:2</option><option value="5">1:5</option><option value="10">1:10</option>
          </select>
          <button onclick="renderLayout()" style="padding:6px 16px;border-radius:8px;background:var(--teal);color:white;border:none;font-size:13px;cursor:pointer;">Refresh</button>
          <span style="width:1px;height:20px;background:var(--border);"></span>
          <label style="font-size:13px;color:var(--subtle);" title="CNC machining offset — adds dashdot layer to DXF (Shapely offset_curve)">CNC Offset:</label>
          <input id="cnc-offset" type="number" value="0" step="0.5" min="-50" max="50"
            style="width:64px;padding:6px 8px;border-radius:8px;border:1px solid var(--border);background:var(--surface);color:var(--text);font-size:13px;font-family:'Fira Code',monospace;"
            title="Positive = expand (outer tool path), Negative = shrink (inner path)" />
          <label style="font-size:12px;color:var(--muted);">mm</label>
        </div>

        <div style="background:#fff;border-radius:12px;overflow:hidden;display:flex;justify-content:center;box-shadow:0 0 0 1px var(--border);">
          <canvas id="layout-canvas" style="max-width:100%;display:block;"></canvas>
        </div>

        <div style="display:flex;justify-content:space-between;margin-top:20px;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
          <button onclick="nextStep()" style="padding:10px 26px;border-radius:10px;font-size:14px;font-weight:600;border:none;background:var(--teal);color:white;cursor:pointer;">Continue → Export</button>
        </div>
      </section>

      <!-- ─── STEP 10: Export ─── -->
      <section class="panel" data-panel="10" style="display:none;">
        <h2 style="font-size:22px;font-weight:700;margin:0 0 6px;">Export</h2>
        <p style="color:var(--muted);margin:0 0 28px;font-size:14px;">Download the technical drawing in your chosen format.</p>

        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:32px;" class="export-grid-4">
          <button onclick="exportDXF()" style="padding:24px 16px;border-radius:14px;border:1px solid var(--teal);background:rgba(13,148,136,.08);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:10px;transition:border-color .2s;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
              <line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/>
            </svg>
            <span style="font-size:15px;font-weight:700;color:var(--teal-light);">DXF</span>
            <span style="font-size:12px;color:var(--muted);">AutoCAD / LibreCAD</span>
          </button>

          <button onclick="exportSVG()" style="padding:24px 16px;border-radius:14px;border:1px solid var(--border);background:var(--surface);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:10px;transition:border-color .2s;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="1.5">
              <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/>
            </svg>
            <span style="font-size:15px;font-weight:700;color:var(--text);">SVG</span>
            <span style="font-size:12px;color:var(--muted);">Vector — editable</span>
          </button>

          <button onclick="exportPrint()" style="padding:24px 16px;border-radius:14px;border:1px solid var(--border);background:var(--surface);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:10px;transition:border-color .2s;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="1.5">
              <polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>
            </svg>
            <span style="font-size:15px;font-weight:700;color:var(--text);">PDF / Print</span>
            <span style="font-size:12px;color:var(--muted);">Open in Print → Save as PDF</span>
          </button>

          <button onclick="exportPNG()" style="padding:24px 16px;border-radius:14px;border:1px solid var(--border);background:var(--surface);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:10px;transition:border-color .2s;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
            </svg>
            <span style="font-size:15px;font-weight:700;color:var(--text);">PNG</span>
            <span style="font-size:12px;color:var(--muted);">Image — for sharing</span>
          </button>
        </div>

        <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;text-align:center;">
          <div style="font-size:13px;color:var(--muted);margin-bottom:8px;">Preview</div>
          <canvas id="export-preview" style="max-width:100%;border-radius:8px;background:#fff;"></canvas>
        </div>

        <div style="margin-top:20px;text-align:center;">
          <button onclick="prevStep()" style="padding:10px 22px;border-radius:10px;font-size:14px;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);cursor:pointer;">← Back</button>
        </div>
      </section>

    </main>
  </div>
</div>

